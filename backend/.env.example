# OutBid Backend Environment Variables

# ============================================================================
# Application
# ============================================================================
PORT=4000
NODE_ENV=development
API_URL=http://localhost:4000

# ============================================================================
# Database (PostgreSQL 16)
# ============================================================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/outbid

# ============================================================================
# Redis (Cache & PubSub)
# ============================================================================
# Format: redis://host:port
REDIS_URL=redis://localhost:6379

# ============================================================================
# JWT & Session Management
# ============================================================================
# Must be at least 32 characters for production
JWT_SECRET=your-super-secret-key-change-in-production-minimum-32-chars
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ============================================================================
# CORS & Frontend
# ============================================================================
# Frontend URL (for CORS and redirects)
CLIENT_URL=http://localhost:3000

# ============================================================================
# Stripe Integration
# ============================================================================
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# Paystack Integration (M-Pesa via Paystack)
# ============================================================================
# Get keys from: https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_WEBHOOK_SECRET=...

# ============================================================================
# Thirdweb Integration (Crypto Payments)
# ============================================================================
# For testnet initially, switch to mainnet for production
THIRDWEB_SECRET_KEY=...
THIRDWEB_CLIENT_ID=...
THIRDWEB_NETWORK=sepolia

# ============================================================================
# Email Service (for password reset, email verification)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password
SMTP_FROM=noreply@outbid.app

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
LOG_FORMAT=json

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_GUEST_SESSIONS=true
REQUIRE_EMAIL_VERIFICATION=false
ENABLE_SOCIAL_LOGIN=false

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# ============================================================================
# Game Settings
# ============================================================================
MATCH_TIMEOUT_SECONDS=600
BID_SUBMISSION_TIMEOUT_SECONDS=180
REVEAL_DELAY_SECONDS=5

# ============================================================================
# KYC Tiers (daily withdrawal limits in cents)
# ============================================================================
KYC_TIER_1_LIMIT=100000
KYC_TIER_2_LIMIT=1000000
KYC_TIER_3_LIMIT=10000000

# ============================================================================
# Admin (Optional)
# ============================================================================
# Admin API key for server-to-server communication
ADMIN_API_KEY=admin-secret-key-change-in-production
